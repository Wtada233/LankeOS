#!/bin/bash

lankebuild_prepare() {
    :
}

lankebuild_build() {
    # Apply custom configuration
    cp /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./work/../linux.cfg .config
    make oldconfig

    # Compile kernel and modules
    make -j$(nproc)

    # Install modules and headers
    make INSTALL_MOD_PATH=/home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root modules_install
    make headers_install ARCH=x86_64 INSTALL_HDR_PATH=/home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/usr

    # Install kernel image
    mkdir -p /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/mnt/base/boot
    cp arch/x86/boot/bzImage /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/mnt/base/boot/vmlinuz-lanke
    cp System.map /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/mnt/base/boot/System.map-lanke
    cp .config /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/mnt/base/boot/config-lanke

    # Cleanup symlinks and strip modules
    find /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/usr/lib/modules -type l -name "build" -delete
    find /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/usr/lib/modules -type l -name "source" -delete
    find /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/linux/./root/usr/lib/modules -name "*.ko" -exec strip --strip-debug {} +
}

lankebuild_package() {
    :
}
