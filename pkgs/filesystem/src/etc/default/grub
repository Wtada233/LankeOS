GRUB_TIMEOUT=10
GRUB_DISTRIBUTOR="LankeOS"
GRUB_CMDLINE_LINUX_DEFAULT="loglevel=3 console=ttyS0,115200 console=tty0"
GRUB_GFXMODE=auto
GRUB_FONT="/usr/share/lankeos/fonts/unicode.pf2"
GRUB_TERMINAL_INPUT="serial console"
GRUB_TERMINAL_OUTPUT="serial gfxterm"
GRUB_SERIAL_COMMAND="serial --unit=0 --speed=115200 --word=8 --parity=no --stop=1"
