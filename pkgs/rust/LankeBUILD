#!/bin/bash

lankebuild_prepare() {
    # 进入解压后的源码目录
    cd rustc-1.96.0-src || exit 1

    # 应用所有补丁（来自 work_sources）
    for patch in ../*.patch; do
        if [ -f "$patch" ]; then
            echo "Applying patch: $patch"
            patch -Np1 < "$patch"
        fi
    done
}

lankebuild_build() {
    cd rustc-1.96.0-src || exit 1

    # 生成 bootstrap.toml（适配 LankeOS x86_64）
    cat > bootstrap.toml << EOF
[build]
vendor = true
target = ["x86_64-unknown-linux-gnu"]
docs = false

[llvm]
download-ci-llvm = false
static-libstdcpp = false
ninja = true
link-shared = true

[rust]
debug = false
debug-assertions = false
debuginfo-level = 0
incremental = false
parallel-frontend-threads = $(nproc)

[target.x86_64-unknown-linux-gnu]
llvm-config = "{BINDIR}/llvm-config"

[install]
prefix = "/usr"
EOF

    DESTDIR="{STAGING_ROOT}" python3 x.py install -j "$(nproc)"
}

lankebuild_package() {
    # 删除 rust-src 及其他无用文件（减小包体积）
    rm -rf "{STAGING_ROOT}{LIBDIR}/rustlib/rustc-src"
    rm -rf "{STAGING_ROOT}{LIBDIR}/rustlib/src"
    rm -f  "{STAGING_ROOT}{LIBDIR}/rustlib/uninstall.sh"
    rm -f  "{STAGING_ROOT}{LIBDIR}/rustlib/install.log"
    rm -f  "{STAGING_ROOT}{LIBDIR}/rustlib/components"
    rm -rf "{STAGING_ROOT}{LIBDIR}/rustlib/etc"
    rm -f  "{STAGING_ROOT}{LIBDIR}/rustlib/rust-installer-version"
    rm -f  "{STAGING_ROOT}{LIBDIR}/rustlib/manifest-*"
}
