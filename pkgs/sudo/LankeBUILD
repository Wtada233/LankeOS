#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    :
}

lankebuild_build() {
    ./configure --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --libexecdir=/usr/lib --with-secure-path --with-all-insults --with-env-editor --disable-static --disable-doc
    make -j$(nproc)
    make DESTDIR={STAGING_ROOT} install
    ln -sfv sudo {STAGING_ROOT}{BINDIR}/sudoedit
}

lankebuild_package() {
    # Installation handled by builder
    mkdir -p "{STAGING_ROOT}{SYSCONFDIR}/pam.d"
    cat > "{STAGING_ROOT}{SYSCONFDIR}/pam.d/sudo" << 'EOF'
#%PAM-1.0

# 认证阶段
auth        required    pam_env.so
auth        sufficient  pam_rootok.so
auth        required    pam_unix.so

# 账户管理阶段
account     required    pam_unix.so

# 会话管理阶段
session     required    pam_unix.so
session     optional    pam_keyinit.so revoke
session     required    pam_limits.so
session     optional    pam_loginuid.so
EOF
}
