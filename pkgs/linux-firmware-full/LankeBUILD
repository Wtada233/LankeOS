#!/bin/bash

lankebuild_prepare() {
    :
}

lankebuild_build() {
    # Step 1: Install ALL firmware files (uncompressed, no zstd).
    # copy-firmware.sh 根据 WHENCE 中的 File/Link 条目自动创建
    # 子目录下的实际文件 + 根目录下的兼容软链接（iwlwifi、ibt、i915 等）
    make -C "{SRC_DIR}"                                         \
        DESTDIR="{STAGING_ROOT}"                                \
        FIRMWAREDIR="/usr/lib/firmware"                         \
        install                                                 \
        NUM_JOBS=$(nproc)

    # Step 2: Install vendor license manifest and all per-vendor licenses
    mkdir -p "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}"
    cp "{SRC_DIR}/WHENCE"                                       \
        "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}/"          \
        2>/dev/null || true
    cp -r "{SRC_DIR}/LICENSES/"*                                \
        "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}/"          \
        2>/dev/null || true
}

lankebuild_package() {
    :
}
