lankebuild_prepare() {
    cd "{SRC_DIR}"
    meson setup build . --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --default-library=shared -Dlegacy=true
}
lankebuild_build() {
    cd "{SRC_DIR}"
    ninja -C build
}
lankebuild_package() {
    cd "{SRC_DIR}"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
    # Clean up headers that belong to libX11 (Arch-style)
    rm -f "{STAGING_ROOT}{INCLUDEDIR}/X11/extensions/XKBgeom.h"
}
