lankebuild_build() {
    mkdir build && cd build
    meson setup .. --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --buildtype=release -Dintrospection=enabled -Dtests=false
    ninja -j$(nproc)
    DESTDIR={STAGING_ROOT} ninja install
}

