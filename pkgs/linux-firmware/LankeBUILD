    # Step 3: Clean broken symlinks
    find . -xtype l -delete
    cd - >/dev/null || true

    # Step 4: Install licenses
    mkdir -p "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}"
    cp "{SRC_DIR}/WHENCE"                                   \
        "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}/"      \
        2>/dev/null || true
    cp -r "{SRC_DIR}/LICENSES/"*                             \
        "{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}/"      \
        2>/dev/null || true

    # Step 5: Remove licenses for deleted firmware.
    # Keeps licenses whose firmware directory exists.
    # Also keeps standard OSI licenses and well-known firmware licenses
    # that don't have a 1:1 firmware directory mapping.
    fwdir="{STAGING_ROOT}/usr/lib/firmware"
    licdir="{STAGING_ROOT}/usr/share/licenses/{PKG_NAME}"
    for f in "$licdir"/{LICEN*,NOTICE*}; do
        [ -f "$f" ] || continue
        base=$(basename "$f")
        # Strip LICEN[CS]E. or NOTICE. prefix
        dirname="${base#LICENCE.}"
        dirname="${dirname#LICENSE.}"
        dirname="${dirname#NOTICE.}"
        # Always keep: standard OSI licenses, WHENCE, no-prefix files
        case "$dirname" in
            "$base"|GPL-*|MIT|Apache-*|WHENCE|BSDL-*) continue ;;
        esac
        # Keep well-known firmware licenses even without matching dir:
        # iwlwifi (in intel/iwlwifi/), bcm43xx (in brcm/ or cypress/),
        # ibt/ibt_firmware (in intel/), atheros/atmar8k (in ath*/ or ar3k/)
        case "$dirname" in
            iwlwifi_firmware|broadcom_bcm43xx|ibt_firmware) continue ;;
            atmar8k|ar3k|Qualcomm*) continue ;;
        esac
        [ -d "$fwdir/$dirname" ] || rm -rf "$f"
    done
