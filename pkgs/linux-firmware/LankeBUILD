#!/bin/bash

lankebuild_prepare() {
    mkdir -p {STAGING_ROOT}/usr/lib/firmware
}

lankebuild_build() {
    local whitelist=(
        "intel/iwlwifi/*-so-a0*" "intel/iwlwifi/*-cc-a0*" "intel/iwlwifi/*-Qu*" "intel/iwlwifi/*-ty-a0*" "intel/iwlwifi/*-bz-*" "intel/iwlwifi/*.pnvm"
        "intel/ibt*" "i915/adls_*" "i915/adlp_*" "i915/tgl_*" "i915/dg2_*" "i915/mtl_*"
        "intel/sof/*" "intel/sof-tplg/*" "intel/avs/*"
        "amdgpu/gc_11_*" "amdgpu/gc_10_*" "amdgpu/navi*"
        "amdgpu/vcn_*" "amdgpu/psp_*" "amdgpu/dcn_*" "amdgpu/sdma_*"
        "amd-ucode/*" "rtl_nic/rtl81*" "intel-ucode/*"
    )

    for pattern in "${whitelist[@]}"; do
        # 修复：匹配 ./ 开头的路径
        find . -path "./$pattern" | while read -r src_file; do
            # 修复：直接去掉开头的 "./"
            local rel_path="${src_file#./}"
            local target_dir=$(dirname "{STAGING_ROOT}/usr/lib/firmware/$rel_path")
            mkdir -p "$target_dir"
            cp -a "$src_file" "{STAGING_ROOT}/usr/lib/firmware/$rel_path"
        done
    done

    cp WHENCE LICEN* "{STAGING_ROOT}/usr/lib/firmware/" 2>/dev/null || true
    cd "{STAGING_ROOT}/usr/lib/firmware/"
    ln -sf intel/iwlwifi/iwlwifi-* .
}

lankebuild_package() {
    :
}
