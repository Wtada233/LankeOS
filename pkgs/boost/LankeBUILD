#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    :
}

lankebuild_build() {
    ./bootstrap.sh --prefix={PREFIX}

    # 第一阶段：构建（stage），生成库文件到 stage/ 目录
    ./b2 stage -j$(nproc) threading=multi link=shared

    # 第二阶段：安装（install），将构建好的库安装到 STAGING_ROOT
    ./b2 install \
        --prefix="{STAGING_ROOT}/usr" \
        --includedir="{STAGING_ROOT}{INCLUDEDIR}" \
        --libdir="{STAGING_ROOT}{LIBDIR}" \
        threading=multi \
        link=shared \
        --layout=system \
        variant=release

    # 修复硬编码路径
    find "{STAGING_ROOT}" -type f \( -name "*.cmake" -o -name "*.pc" \) -exec sed -i "s|{STAGING_ROOT}||g" {} +
}

lankebuild_package() {
    # Installation handled by builder
    :
}
