#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    :
}

lankebuild_build() {
    for dir in */; do
        if [ -d "$dir" ]; then
            cd "$dir"
            break
        fi
    done
    patch -Np1 -i {WORK_DIR}/expect-5.45.4-gcc15-1.patch
    ./configure --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --with-tcl={LIBDIR} --enable-shared --disable-rpath --mandir={MANDIR} --with-tclinclude={INCLUDEDIR} --disable-static
    make -j$(nproc)
    make DESTDIR={STAGING_ROOT} install
    ln -svf expect5.45.4/libexpect5.45.4.so {STAGING_ROOT}{LIBDIR}/
}


lankebuild_package() {
    # Installation handled by builder
    :
}
