#!/bin/bash
lankebuild_prepare() {
    :
}

lankebuild_build() {
    mkdir -p {STAGING_ROOT}{DATADIR}/fonts/noto-cjk
    # hooks dir created by builder

    cp NotoSansMonoCJKsc-Regular.otf {STAGING_ROOT}{DATADIR}/fonts/noto-cjk/
    chmod 644 {STAGING_ROOT}{DATADIR}/fonts/noto-cjk/NotoSansMonoCJKsc-Regular.otf

    cat > {STAGING_HOOKS}/postinst.sh <<EOF
#!/bin/sh
if command -v fc-cache >/dev/null 2>&1; then
    echo "=> 正在刷新系统字体缓存 (Mono)..."
    fc-cache -fv {DATADIR}/fonts/noto-cjk
fi
EOF
    # chmod set by builder
}

lankebuild_package() {
    :
}
