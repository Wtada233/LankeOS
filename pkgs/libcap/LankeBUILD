#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    sed -i '/install -m.*STA/d' libcap/Makefile
}

lankebuild_build() {
    make prefix=/usr lib=lib -j$(nproc)
    make prefix=/usr lib=lib DESTDIR={STAGING_ROOT} install
}


