#!/bin/bash

lankebuild_prepare() {
    cd $(ls -d */ | head -1)

    # 下载所有依赖（锁定版本）
    cargo fetch --locked --target "$(rustc --print host-tuple)"
    patch -p1 < {WORK_DIR}/allow-software-rendering.patch
}

lankebuild_build() {
    cd $(ls -d */ | head -1)

    # 嵌入构建标识（用于 niri --version）
    export NIRI_BUILD_COMMIT="{PKG_VER}"

    # 添加 LTO 兼容标志
    export CFLAGS="${CFLAGS} -ffat-lto-objects"

    # 编译 niri（含默认特性：wayland + x11 后端等）
    cargo build --frozen --release --features default

    # 生成 Shell 自动补全
    for shell in bash fish zsh; do
        cargo run --frozen --release --bin niri -- \
            completions "$shell" > "$shell-completions"
    done
}

lankebuild_package() {
    cd $(ls -d */ | head -1)

    # 主程序与会话脚本
    install -vDm 755 target/release/niri "{STAGING_ROOT}{BINDIR}/niri"
    install -vDm 755 resources/niri-session "{STAGING_ROOT}{BINDIR}/niri-session"

    # systemd 用户单元
    install -vDm 644 resources/niri.service \
        "{STAGING_ROOT}{LIBDIR}/systemd/user/niri.service"
    install -vDm 644 resources/niri-shutdown.target \
        "{STAGING_ROOT}{LIBDIR}/systemd/user/niri-shutdown.target"

    # Wayland 会话入口
    install -vDm 644 resources/niri.desktop \
        "{STAGING_ROOT}{DATADIR}/wayland-sessions/niri.desktop"

    # XDG Desktop Portal 配置
    install -vDm 644 resources/niri-portals.conf \
        "{STAGING_ROOT}{DATADIR}/xdg-desktop-portal/niri-portals.conf"

    # 文档
    install -vDm 644 resources/default-config.kdl \
        "{STAGING_ROOT}{DATADIR}/doc/niri/default-config.kdl"
    install -vDm 644 README.md \
        "{STAGING_ROOT}{DATADIR}/doc/niri/README.md"

    # Shell 补全
    install -vDm 644 bash-completions \
        "{STAGING_ROOT}{DATADIR}/bash-completion/completions/niri"
    install -vDm 644 fish-completions \
        "{STAGING_ROOT}{DATADIR}/fish/vendor_completions.d/niri.fish"
    install -vDm 644 zsh-completions \
        "{STAGING_ROOT}{DATADIR}/zsh/site-functions/_niri"
}
