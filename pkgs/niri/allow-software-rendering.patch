+    pub fn render(
+        &mut self,
+        niri: &mut Niri,
+        output: &Output,
+        target_presentation_time: Duration,
+    ) -> RenderResult {
+        let span = tracy_client::span!("Tty::render");
+
+        let tty_state: &TtyOutputState = output.user_data().get().unwrap();
+        let Some(device) = self.devices.get_mut(&tty_state.node) else {
+            error!("missing output device");
+            return RenderResult::Skipped;
+        };
+
+        let Some(surface) = device.surfaces.get_mut(&tty_state.crtc) else {
+            error!("missing surface");
+            return RenderResult::Skipped;
+        };
+
+        span.emit_text(&surface.name.connector);
+
+        if !device.drm.is_active() {
+            // This branch hits any time we try to render while the user had switched to a
+            // different VT, so don't print anything here.
+            return RenderResult::Skipped;
+        }
+
+        // Try hardware renderer first – fast path for real GPUs.
+        match self.gpu_manager.renderer(
+            &self.primary_render_node,
+            &device.render_node.unwrap_or(self.primary_render_node),
+            surface.compositor.format(),
+        ) {
+            Ok(mut renderer) => {
+                let config = self.config.borrow();
+                return Self::render_with_renderer(
+                    &mut renderer,
+                    niri,
+                    output,
+                    surface,
+                    &config,
+                    target_presentation_time,
+                );
+            }
+            Err(err) => {
+                trace!("hardware renderer unavailable, trying software fallback: {err:?}");
+            }
+        }
+
+        // Software fallback — the software renderer should have been set up in
+        // device_added() when the hardware EGL/GLES init succeeded but the
+        // actual GLES context creation failed.
+        let Some(sw_renderer) = &mut self.software_renderer else {
+            error!("no renderer available; try running with Mesa's software rasterizer installed");
+            return RenderResult::Skipped;
+        };
+
+        let config = self.config.borrow();
+        Self::render_with_renderer(
+            sw_renderer,
+            niri,
+            output,
+            surface,
+            &config,
+            target_presentation_time,
+        )
+    }
