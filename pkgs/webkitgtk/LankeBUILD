#!/bin/sh
set -e

lankebuild_prepare() {
    echo "Applying WebKitGTK patches..."

    # BLFS 推荐的 BBQJIT.cpp 修复
    sed '/returnLocation.isStackArgument/,/returnLocation = canonicalLocation/d' \
        -i Source/JavaScriptCore/wasm/WasmBBQJIT.cpp || true

    mkdir -p build
}

lankebuild_build() {
    echo "Configuring WebKitGTK-2.50.5..."
    echo "  USE_GTK4=ON  — GTK4 后端"
    echo "  ENABLE_MINIBROWSER=ON — 内置 MiniBrowser"
    echo ""

    cd build

    cmake -D CMAKE_BUILD_TYPE=Release         \
          -D CMAKE_INSTALL_PREFIX={PREFIX}        \
          -DCMAKE_INSTALL_SYSCONFDIR={SYSCONFDIR} \
          -D CMAKE_SKIP_INSTALL_RPATH=ON      \
          -D PORT=GTK                         \
          -D LIB_INSTALL_DIR={LIBDIR}         \
          -D USE_LIBBACKTRACE=OFF             \
          -D USE_LIBHYPHEN=OFF                \
          -D ENABLE_GAMEPAD=OFF               \
          -D ENABLE_MINIBROWSER=ON            \
          -D ENABLE_DOCUMENTATION=OFF         \
          -D USE_WOFF2=OFF                    \
          -D USE_GTK4=ON                      \
          -D ENABLE_BUBBLEWRAP_SANDBOX=OFF    \
          -D USE_SYSPROF_CAPTURE=NO           \
          -D ENABLE_SPEECH_SYNTHESIS=OFF      \
          -D ENABLE_GEOLOCATION=OFF           \
          -D USE_AVIF=OFF                     \
          -D USE_JPEGXL=OFF                   \
          -D ENABLE_WEBDRIVER=OFF             \
          -D ENABLE_INTROSPECTION=OFF        \
          -D ENABLE_SPELLCHECK=OFF            \
          -W no-dev -G Ninja ..

    echo ""
    echo "Building WebKitGTK-2.50.5..."
    echo "注意: 本步骤可能耗时 2~5 小时"
    echo "根据内存调整并行数: 每 4 GiB RAM 配 1 job"
    echo "  32 GiB → ninja -j8"
    echo "  16 GiB → ninja -j4"
    echo "   8 GiB → ninja -j2"
    echo ""

    # 检测内存自动控制并行度
    TOTAL_MEM=$(awk '/MemTotal/ {printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || echo "8192")
    JOBS=$(( TOTAL_MEM / 4096 + 1 ))
    [ "$JOBS" -gt 8 ] && JOBS=8
    [ "$JOBS" -lt 1 ] && JOBS=1
    echo "检测到 ${TOTAL_MEM} MiB 内存, 使用 -j${JOBS}"

    ninja -j${JOBS}
    echo "Build complete."
}

lankebuild_package() {
    echo "Packaging WebKitGTK-2.50.5..."
    cd build
    DESTDIR="{STAGING_ROOT}" ninja install

    for dir in "{STAGING_ROOT}{LIBDIR}exec"/webkit*/; do
        [ -d "$dir" ] || continue
        [ -f "${dir}MiniBrowser" ] || continue
        mkdir -p "{STAGING_ROOT}{BINDIR}"
        ln -sf "../libexec/$(basename "${dir%/}")/MiniBrowser" \
            "{STAGING_ROOT}{BINDIR}/MiniBrowser"
        break
    done
    echo "Package staging complete."
}
