lankebuild_prepare() {
    cd "{SRC_DIR}"
    meson setup build . --prefix=/usr --default-library=shared --buildtype=release
}
lankebuild_build() {
    cd "{SRC_DIR}"
    ninja -C build -j$(nproc)
}
lankebuild_package() {
    cd "{SRC_DIR}"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
    rm -rf "{STAGING_ROOT}/usr/share/X11/xkb"
    ln -sf ../xkeyboard-config-2 "{STAGING_ROOT}/usr/share/X11/xkb"
}
