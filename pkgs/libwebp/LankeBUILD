#!/bin/sh
set -e

lankebuild_prepare() {
    mkdir -p build
}

lankebuild_build() {
    echo "Configuring libwebp-1.5.0..."
    cd build
    cmake .. -G Ninja \
        -DCMAKE_INSTALL_PREFIX={PREFIX} \
        -DCMAKE_INSTALL_SYSCONFDIR={SYSCONFDIR} \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=ON
    echo "Building libwebp-1.5.0..."
    ninja -j$(nproc)
    echo "Build complete."
}

lankebuild_package() {
    echo "Packaging libwebp-1.5.0..."
    cd build
    DESTDIR="{STAGING_ROOT}" ninja install
    echo "Package staging complete."
}
