lankebuild_prepare() {
    cd "{SRC_DIR}"
    meson setup build . --prefix=/usr --default-library=shared --buildtype=release \
        -Db_ndebug=true \
        -Damdgpu-virtio=true \
        -Dandroid-libbacktrace=disabled \
        -Dgallium-drivers=iris,nouveau,radeonsi,llvmpipe,zink,virgl,svga \
        -Dgallium-extra-hud=true \
        -Dgallium-mediafoundation=disabled \
        -Dgallium-rusticl=true \
        -Dgallium-rusticl-enable-drivers=radeonsi \
        -Dgles1=disabled \
        -Dintel-rt=enabled \
        -Dintel-virtio-experimental=true \
        -Dlibunwind=disabled \
        -Dmicrosoft-clc=disabled \
        -Dvalgrind=disabled \
        -Dvideo-codecs=all \
        -Dvulkan-drivers=intel,amd,swrast \
        -Dvulkan-layers=device-select,intel-nullhw,overlay,screenshot,anti-lag,vram-report-limit \
        -Dvulkan-manifest-per-architecture=false
}
lankebuild_build() {
    cd "{SRC_DIR}"
    ninja -C build
}
lankebuild_package() {
    cd "{SRC_DIR}"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
}
