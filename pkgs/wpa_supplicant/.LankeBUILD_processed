#!/bin/bash

lankebuild_prepare() {
    mv *.patch fix.patch
    cd /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./work/wpa_supplicant*
    patch -Np1 -i /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./work/fix.patch

    cat > wpa_supplicant/.config << "EOF"
CONFIG_BACKEND=file
CONFIG_CTRL_IFACE=y
CONFIG_DEBUG_FILE=y
CONFIG_DEBUG_SYSLOG=y
CONFIG_DEBUG_SYSLOG_FACILITY=LOG_DAEMON
CONFIG_DRIVER_NL80211=y
CONFIG_DRIVER_WEXT=y
CONFIG_DRIVER_WIRED=y
CONFIG_EAP_GTC=y
CONFIG_EAP_LEAP=y
CONFIG_EAP_MD5=y
CONFIG_EAP_MSCHAPV2=y
CONFIG_EAP_OTP=y
CONFIG_EAP_PEAP=y
CONFIG_EAP_TLS=y
CONFIG_EAP_TTLS=y
CONFIG_IEEE8021X_EAPOL=y
CONFIG_IPV6=y
CONFIG_LIBNL32=y
CONFIG_PEERKEY=y
CONFIG_PKCS12=y
CONFIG_READLINE=y
CONFIG_SMARTCARD=y
CONFIG_WPS=y
CFLAGS += -I/usr/include/libnl3
EOF

    if pkg-config --exists dbus-1 2>/dev/null; then
        cat >> wpa_supplicant/.config << "EOF"
CONFIG_CTRL_IFACE_DBUS=y
CONFIG_CTRL_IFACE_DBUS_NEW=y
CONFIG_CTRL_IFACE_DBUS_INTRO=y
EOF
    fi
}

lankebuild_build() {
    cd /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./work/wpa_supplicant*/wpa_supplicant

    # 编译
    make BINDIR=/usr/sbin LIBDIR=/usr/lib

    # 安装二进制文件到目标根目录
    install -v -d /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/sbin
    install -v -m755 wpa_cli wpa_passphrase wpa_supplicant /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/sbin/

    # 安装手册页
    install -v -d /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/man/man5 /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/man/man8
    install -v -m644 doc/docbook/wpa_supplicant.conf.5 /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/man/man5/
    install -v -m644 doc/docbook/wpa_{cli,passphrase,supplicant}.8 /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/man/man8/

    # 若启用 D-Bus，安装相关服务文件
    if pkg-config --exists dbus-1 2>/dev/null; then
        install -v -d /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/dbus-1/system-services
        install -v -m644 dbus/fi.w1.wpa_supplicant1.service \
            /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/usr/share/dbus-1/system-services/
        install -v -d /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/etc/dbus-1/system.d
        install -v -m644 dbus/dbus-wpa_supplicant.conf \
            /home/Wtada233/Projects/LFS/files/LankeOS/pkgs/wpa_supplicant/./root/etc/dbus-1/system.d/wpa_supplicant.conf
    fi
}

lankebuild_package() {
    # 打包由构建系统自动处理
    :
}
