#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    :
}

lankebuild_build() {
    # LFS 12.4 推荐：确保 python 脚本指向 python3
    grep -rl '^#!.*python$' | xargs sed -i '1s/python/&3/'
    mkdir build && cd build
    meson setup .. --prefix=/usr --buildtype=release -Ddefault_library=shared -Dpolkit=true -Dintrospection=true -Dnmtui=true -Dppp=false -Dlibaudit=no -Dselinux=false -Dcrypto=gnutls -Dmodem_manager=false -Dovs=false -Dnm_cloud_setup=false -Dqt=false -Dnbft=false -Dsession_tracking=systemd -Dlibpsl=true
    ninja -j$(nproc)
    DESTDIR={STAGING_ROOT} ninja install
    # 创建官方推荐的基础配置
    mkdir -pv {STAGING_ROOT}/etc/NetworkManager/conf.d
    cat > {STAGING_ROOT}/etc/NetworkManager/NetworkManager.conf << "EOF"
[main]
plugins=keyfile
EOF
    cat > {STAGING_ROOT}/etc/NetworkManager/conf.d/polkit.conf << "EOF"
[main]
auth-polkit=true
EOF
    # 写入 NetworkManager 的 Polkit 权限规则 (允许 netdev 组)
    mkdir -pv {STAGING_ROOT}/usr/share/polkit-1/rules.d
    cat > {STAGING_ROOT}/usr/share/polkit-1/rules.d/org.freedesktop.NetworkManager.rules << "EOF"
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("org.freedesktop.NetworkManager.") == 0 && subject.isInGroup("netdev")) {
        return polkit.Result.YES;
    }
});
EOF
    cat >> "{STAGING_HOOKS}/postinst.sh" << 'EOF'
getent group netdev >/dev/null || groupadd -fg 86 netdev
systemctl enable NetworkManager
EOF
}


lankebuild_package() {
    # Installation handled by builder
    :
}
