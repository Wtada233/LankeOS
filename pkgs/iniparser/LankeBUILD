lankebuild_build() {
    mkdir build && cd build
    cmake -G Ninja .. \
        -DCMAKE_INSTALL_PREFIX={PREFIX} \
        -DCMAKE_INSTALL_SYSCONFDIR={SYSCONFDIR} \
        -DBUILD_SHARED_LIBS=ON \
        -DBUILD_STATIC_LIBS=OFF \
        -DCMAKE_BUILD_TYPE=Release
    DESTDIR={STAGING_ROOT} ninja install
}

