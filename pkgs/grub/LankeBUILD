#!/bin/bash

lankebuild_prepare() {
    # Prepare environment
    :
}

lankebuild_build() {
    # LFS 安全性修复：移除可能破坏引导程序的优化标志
    unset {C,CPP,CXX,LD}FLAGS
    # 补充源码包发布时缺失的文件
    echo depends bli part_gpt  > grub-core/extra_deps.lst

    # 仅构建 UEFI 版本，移除 Legacy BIOS 支持
    ./configure --prefix=/usr --sysconfdir=/etc --disable-werror --disable-efiemu --with-platform=efi --target=x86_64 --enable-grub-mkfont --disable-static
    make -j$(nproc)
    make DESTDIR={STAGING_ROOT} install

    mkdir -pv {STAGING_ROOT}/usr/share/bash-completion/completions
    mv -v {STAGING_ROOT}/etc/bash_completion.d/grub {STAGING_ROOT}/usr/share/bash-completion/completions/grub
    # 恢复环境变量以便后续包构建
    export CFLAGS="-O2 -pipe"
    export CXXFLAGS=$CFLAGS
    export LDFLAGS="-Wl,-O1,--sort-common,--as-needed"
    export NO_STRIP=1
    export NO_STRIP=0
}


lankebuild_package() {
    # Installation handled by builder
    :
}
