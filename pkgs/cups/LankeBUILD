lankebuild_prepare() {
    ./configure \
        --prefix={PREFIX} \
        --sysconfdir={SYSCONFDIR} \
        --localstatedir={LOCALSTATEDIR} \
        --disable-static
}

lankebuild_build() {
    cd "{SRC_DIR}"
    make -j$(nproc)
}

lankebuild_package() {
    cd "{SRC_DIR}"
    make DESTDIR="{STAGING_ROOT}" install
}
