lankebuild_prepare() {
    cd "{WORK_DIR}"
    git clone https://github.com/swaywm/sway
    cd sway && git checkout 845cdb19
}
lankebuild_build() {
    cd "{WORK_DIR}/sway"
    meson setup build --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --default-library=shared --buildtype=release \
        -Dsd-bus-provider=libsystemd \
        -Dman-pages=disabled \
        -Ddefault-wallpaper=false \
        -Dwerror=false
    ninja -C build -j$(nproc)
}
lankebuild_package() {
    cd "{WORK_DIR}/sway"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
}
