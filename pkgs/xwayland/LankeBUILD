lankebuild_prepare() {
    cd "{SRC_DIR}"
    meson setup build . --prefix=/usr --default-library=shared \
        -Dc_args='-Wno-error=array-bounds' \
        -Dipv6=true \
        -Dxvfb=false \
        -Dxdmcp=false \
        -Dxcsecurity=true \
        -Dsecure-rpc=false \
        -Ddri3=true \
        -Dglamor=true \
        -Dxkb_dir=/usr/share/X11/xkb \
        -Dxkb_output_dir=/var/lib/xkb
}
lankebuild_build() {
    cd "{SRC_DIR}"
    ninja -C build
}
lankebuild_package() {
    cd "{SRC_DIR}"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
}
