#!/bin/bash

lankebuild_prepare() {
    :
}

lankebuild_build() {
    mkdir -p {STAGING_ROOT}/usr/share/fonts/TTF
    cp -v *.ttf {STAGING_ROOT}/usr/share/fonts/TTF/
    chmod 644 {STAGING_ROOT}/usr/share/fonts/TTF/*.ttf

    cat > {STAGING_HOOKS}/postinst.sh <<'EOF'
#!/bin/sh
if command -v fc-cache >/dev/null 2>&1; then
    echo "=> 刷新字体缓存..."
    fc-cache -fv /usr/share/fonts/TTF
fi
EOF
}

lankebuild_package() {
    :
}
