lankebuild_prepare() {
    cd "{SRC_DIR}"
    meson setup build . --prefix={PREFIX} --sysconfdir={SYSCONFDIR} --default-library=shared --buildtype=release \
        -Dexamples=false \
        -Dbackends=drm,libinput \
        -Drenderers=gles2,vulkan \
        -Dsession=enabled \
        -Dxwayland=enabled \
        -Dwerror=false
}
lankebuild_build() {
    cd "{SRC_DIR}"
    ninja -C build -j$(nproc)
}
lankebuild_package() {
    cd "{SRC_DIR}"
    DESTDIR="{STAGING_ROOT}" ninja -C build install
}
